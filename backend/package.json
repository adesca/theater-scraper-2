    "express": "^5.2.1",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "happy-dom": "^20.10.6",
    "is-odd": "^3.0.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
